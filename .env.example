# API key de ENTIA (requerida para tools autenticadas: search_entities, run_risk_audit)
ENTIA_API_KEY=your_entia_api_key_here

# Base URL de la API (no cambiar en produccion)
ENTIA_API_BASE=https://entia.systems

# Transport: 'stdio' para Claude Code local, 'http' para Cloud Run / Managed Agents
MCP_TRANSPORT=stdio

# Puerto HTTP (solo si MCP_TRANSPORT=http)
MCP_PORT=3000
